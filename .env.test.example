# Integration test environment variables
# Copy this file to .env.test and fill in real values.
# .env.test is gitignored — never commit real API keys.

# ── OpenAI Protocol ──
AGENTIC_TEST_OPENAI_API_KEY=sk-your-openai-key
AGENTIC_TEST_OPENAI_BASE_URL=https://api.openai.com/v1
AGENTIC_TEST_OPENAI_MODEL=gpt-4o

# ── Anthropic Protocol ──
AGENTIC_TEST_ANTHROPIC_API_KEY=sk-your-anthropic-key
AGENTIC_TEST_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
AGENTIC_TEST_ANTHROPIC_MODEL=claude-sonnet-4-20250514
