{
    "name": "chen-zhanjie/hyperf-agentic",
    "description": "Hyperf-native AI Agent SDK — config-driven, Hermes-inspired",
    "type": "hyperf-extension",
    "license": "MIT",
    "version": "1.0.0",
    "require": {
        "php": ">=8.1",
        "psr/log": "^2.0|^3.0",
        "symfony/yaml": "^6.0|^7.0",
        "symfony/console": "^6.0|^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "hyperf/contract": "~3.1"
    },
    "autoload": {
        "psr-4": {
            "ChenZhanjie\\Agentic\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ChenZhanjie\\Agentic\\Tests\\": "tests/"
        }
    },
    "extra": {
        "hyperf": {
            "config": "ChenZhanjie\\Agentic\\ConfigProvider"
        }
    }
}
